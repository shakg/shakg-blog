---

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const pageTitle = 'Page Not Found';
---

<BaseLayout title={pageTitle} description="Page not found">
  <Header />
  <main class="container">
    <div class="not-found">
      <h1>404</h1>
      <p>Looks like this page wandered off into the woods.</p>
      <a href="/">← Return home</a>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .not-found {
    padding: 6rem 0;
    text-align: center;
  }

  .not-found h1 {
    font-size: 6rem;
    color: var(--color-surface);
    margin: 0;
  }

  .not-found p {
    font-family: var(--font-ui);
    color: var(--color-secondary);
    font-size: 1.125rem;
    margin-bottom: 2rem;
  }

  .not-found a {
    font-family: var(--font-ui);
    color: var(--color-accent);
  }
</style>